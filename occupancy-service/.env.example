# Upstash REST API (dashboard → Redis → REST API → copy URL + token)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Supabase → Settings → API → JWT Secret (same as used to sign anon/user tokens)
SUPABASE_JWT_SECRET=

# When true, absent/invalid JWT can pair with JSON body.deviceUserId matching anon_* (dev / parity with legacy live_locations)
OCCUPANCY_ALLOW_ANON_DEVICE_ID=true

PORT=8787

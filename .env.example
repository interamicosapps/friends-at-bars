# MapKit JS — create tokens in Apple Developer → Maps → MapKit JS.
#
# Local dev:
#   Copy to .env.local and set VITE_MAPKIT_TOKEN to your test token (localhost).
#   .env.local is gitignored.
#
# Vercel:
#   Project → Settings → Environment Variables → VITE_MAPKIT_TOKEN = production token
#   (domain allowlisted for friends-at-bars-two.vercel.app or your domain).
#
# Codemagic:
#   App → Environment variables → VITE_MAPKIT_TOKEN (sensitive) so `npm run build` embeds it.
#
VITE_MAPKIT_TOKEN=

# Supabase — project URL and anon key from Supabase dashboard → Settings → API.
VITE_SUPABASE_URL=https://axgeqlomkgdeuvismwyf.supabase.co
VITE_SUPABASE_ANON_KEY=

# Occupancy hybrid API — occupancy-service must listen on port 8787 (Redis + .env there).
# Repo root: npm run dev:with-occupancy starts Vite + occupancy-service together.
# Prefer Vite proxy in dev (phones: 127.0.0.1 is the device, not your PC):
#   VITE_OCCUPANCY_API_URL=/api/occupancy
# Or direct (browser on same machine only): http://127.0.0.1:8787 — no trailing slash.
# Production / preview: full https URL only (no /api/occupancy rewrite).
# Side-by-side green (Redis) / red (Supabase) counts when occupancy URL is set:
# VITE_OCCUPANCY_COMPARISON=1
